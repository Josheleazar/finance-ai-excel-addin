<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<OfficeApp xmlns="http://schemas.microsoft.com/office/appforoffice/1.1" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:bt="http://schemas.microsoft.com/office/officeappbasictypes/1.0" xmlns:ov="http://schemas.microsoft.com/office/taskpaneappversionoverrides" xsi:type="TaskPaneApp">
  <Id>1fe64b63-691b-4295-88db-8aa3e023a09a</Id>
  <Version>1.0.0.0</Version>
  <ProviderName>Josh Eleazar</ProviderName>
  <DefaultLocale>en-US</DefaultLocale>
  <DisplayName DefaultValue="Finalysis"/>
  <Description DefaultValue="Finnhub Data Integration &amp; AI Reconciliation"/>
  <IconUrl DefaultValue="https://improved-lamp-5x675rgjr4qf5qw-3000.app.github.dev/finalysis/assets/icon-32.png"/>
  <HighResolutionIconUrl DefaultValue="https://improved-lamp-5x675rgjr4qf5qw-3000.app.github.dev/finalysis/assets/icon-64.png"/>
  <SupportUrl DefaultValue="https://github.com/Joshtheson/finalysis"/>
  <AppDomains>
    <AppDomain>https://*.app.github.dev</AppDomain>
  </AppDomains>
  <Hosts>
    <Host Name="Workbook"/>
  </Hosts>
  <DefaultSettings>
    <SourceLocation DefaultValue="https://improved-lamp-5x675rgjr4qf5qw-3000.app.github.dev/finalysis/taskpane.html"/>
  </DefaultSettings>
  <Permissions>ReadWriteDocument</Permissions>
  <VersionOverrides xmlns="http://schemas.microsoft.com/office/taskpaneappversionoverrides" xsi:type="VersionOverridesV1_0">
    <Hosts>
      <Host xsi:type="Workbook">
        <DesktopFormFactor>
          <GetStarted>
            <Title resid="GetStarted.Title"/>
            <Description resid="GetStarted.Description"/>
            <LearnMoreUrl resid="GetStarted.LearnMoreUrl"/>
          </GetStarted>
          <FunctionFile resid="Commands.Url"/>
          <ExtensionPoint xsi:type="PrimaryCommandSurface">
            <OfficeTab id="TabHome">
              <Group id="CommandsGroup">
                <Label resid="CommandsGroup.Label"/>
                <Icon>
                  <bt:Image size="16" resid="Icon.16x16"/>
                  <bt:Image size="32" resid="Icon.32x32"/>
                  <bt:Image size="80" resid="Icon.80x80"/>
                </Icon>
                <Control xsi:type="Button" id="TaskpaneButton">
                  <Label resid="TaskpaneButton.Label"/>
                  <Supertip>
                    <Title resid="TaskpaneButton.Label"/>
                    <Description resid="TaskpaneButton.Tooltip"/>
                  </Supertip>
                  <Icon>
                    <bt:Image size="16" resid="Icon.16x16"/>
                    <bt:Image size="32" resid="Icon.32x32"/>
                    <bt:Image size="80" resid="Icon.80x80"/>
                  </Icon>
                  <Action xsi:type="ShowTaskpane">
                    <TaskpaneId>ButtonId1</TaskpaneId>
                    <SourceLocation resid="Taskpane.Url"/>
                  </Action>
                </Control>
              </Group>
            </OfficeTab>
          </ExtensionPoint>
        </DesktopFormFactor>
      </Host>
    </Hosts>
    <Resources>
      <bt:Images>
        <bt:Image id="Icon.16x16" DefaultValue="https://improved-lamp-5x675rgjr4qf5qw-3000.app.github.dev/finalysis/assets/icon-16.png"/>
        <bt:Image id="Icon.32x32" DefaultValue="https://improved-lamp-5x675rgjr4qf5qw-3000.app.github.dev/finalysis/assets/icon-32.png"/>
        <bt:Image id="Icon.80x80" DefaultValue="https://improved-lamp-5x675rgjr4qf5qw-3000.app.github.dev/finalysis/assets/icon-80.png"/>
      </bt:Images>
      <bt:Urls>
        <bt:Url id="GetStarted.LearnMoreUrl" DefaultValue="https://go.microsoft.com/fwlink/?LinkId=276812"/>
        <bt:Url id="Commands.Url" DefaultValue="https://improved-lamp-5x675rgjr4qf5qw-3000.app.github.dev/finalysis/commands.html"/>
        <bt:Url id="Taskpane.Url" DefaultValue="https://improved-lamp-5x675rgjr4qf5qw-3000.app.github.dev/finalysis/taskpane.html"/>
      </bt:Urls>
      <bt:ShortStrings>
        <bt:String id="GetStarted.Title" DefaultValue="Finalysis - Finance AI"/>
        <bt:String id="CommandsGroup.Label" DefaultValue="Finalysis"/>
        <bt:String id="TaskpaneButton.Label" DefaultValue="Open Finalysis"/>
      </bt:ShortStrings>
      <bt:LongStrings>
        <bt:String id="GetStarted.Description" DefaultValue="Pull Finnhub data, reconcile transactions, and get AI insights."/>
        <bt:String id="TaskpaneButton.Tooltip" DefaultValue="Open Finance AI Integrator"/>
      </bt:LongStrings>
    </Resources>
  </VersionOverrides>
</OfficeApp>