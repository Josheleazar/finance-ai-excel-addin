# Finalysis — environment variables
#
# Copy this file to `.env` for local development, and set the same vars in
# Vercel (Production + Preview) for deployed builds.
#
# These values are PUBLIC — they are inlined into the client bundle by webpack
# DefinePlugin. Never put secrets (Clerk Secret Key, etc.) in this file.

# Clerk publishable key. For a development instance this starts with `pk_test_`,
# for production it starts with `pk_live_`. The Clerk Frontend API URL is
# embedded in the key; @clerk/clerk-js derives it automatically.
CLERK_PUBLISHABLE_KEY=pk_test_replace-me
